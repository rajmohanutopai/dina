# Copy to .env and fill in.
# Anything left blank uses the default in docker-compose.yml.

# --- Shared --------------------------------------------------------------
GOOGLE_API_KEY=

# --- Transport ----------------------------------------------------------
# MsgBox relay — required for NAT'd Home Nodes (mobile, cloud → home). Leave
# both blank on a LAN-only setup; the CLI will use DINA_CORE_URL directly.
# For auto (default): CLI tries direct first, falls back to MsgBox.
DINA_MSGBOX_URL=
DINA_HOMENODE_DID=
DINA_TRANSPORT=auto

# --- Provider container --------------------------------------------------
# Core URL seen from inside the container. For dina-mobile on macOS, keep
# host.docker.internal. In a linked-stack setup, use http://<service>:8100.
PROVIDER_DINA_CORE_URL=http://host.docker.internal:8100

# Pairing code from `dina-admin device pair` on the provider Core.
PROVIDER_PAIRING_CODE=

# OpenClaw gateway auth token (arbitrary string; must match whatever the
# provider's Dina Core expects).
PROVIDER_OPENCLAW_TOKEN=provider-oc-token
PROVIDER_DEVICE_NAME=openclaw-provider
PROVIDER_HOOK_CALLBACK_TOKEN=dina-callback-provider-token

# MCP the provider exposes. Default = the transit demo.
# For Dr Carl's appointment MCP, set:
#   PROVIDER_MCP_NAME=appointment
#   PROVIDER_MCP_ARGS=["-m","demo.appointment"]
#   PROVIDER_MCP_PATH=../../demo/appointment
#   PROVIDER_MCP_MODULE=demo/appointment
PROVIDER_MCP_NAME=transit
PROVIDER_MCP_COMMAND=python3
PROVIDER_MCP_ARGS=["-m","demo.transit"]
PROVIDER_MCP_PATH=../../demo/transit
PROVIDER_MCP_MODULE=demo/transit
PROVIDER_MCP_PYTHONPATH=/app

PROVIDER_GATEWAY_PORT=13000

# --- User container ------------------------------------------------------
USER_DINA_CORE_URL=http://host.docker.internal:8100
USER_PAIRING_CODE=
USER_OPENCLAW_TOKEN=user-oc-token
USER_DEVICE_NAME=openclaw-user
USER_HOOK_CALLBACK_TOKEN=dina-callback-user-token

# Required only if the user container reads Gmail via gog.
GOG_KEYRING_PASSWORD=
# GOG_AUTH_PATH=./gog-auth

USER_GATEWAY_PORT=13001
