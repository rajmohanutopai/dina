{
  "expo": {
    "name": "Dina",
    "slug": "dina-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "dina",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/branding/dina-icon.png",
    "splash": {
      "image": "./assets/branding/dina-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F2EC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dinakernel.mobile",
      "icon": "./assets/branding/dina-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/dina-icon.png",
        "backgroundColor": "#E5DDD0"
      },
      "package": "com.dinakernel.mobile"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#3b82f6",
          "defaultChannel": "solicited"
        }
      ]
    ]
  }
}
