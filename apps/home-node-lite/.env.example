# Home Node Lite — environment config.
#
# Copy to `.env` (same directory) before `docker compose up`, or let
# `install-lite.sh` generate one interactively.
#
# See apps/home-node-lite/docker-compose.lite.yml for the matching
# variable names.

# ─── Image tag ─────────────────────────────────────────────────────────
# Pin to a released tag (e.g. `v0.1.0`, `latest`, `sha-abc1234`) or
# keep `dev` to build-from-source locally.
DINA_IMAGE_TAG=dev

# ─── Ports ─────────────────────────────────────────────────────────────
# Host-side ports for the external mapping. Defaults match the Go
# production stack. Set distinct ports when running Lite + production
# side-by-side on one host.
DINA_CORE_PORT_EXTERNAL=8100
DINA_BRAIN_PORT_EXTERNAL=8200

# ─── PDS integration ───────────────────────────────────────────────────
# Leave blank for dev-mode: Core runs without publishing to PDS.
# For Trust Network participation (M3+), set these to a community
# PDS + your Dina account.
DINA_PDS_URL=https://bsky.social
DINA_PDS_HANDLE=
DINA_PDS_PASSWORD=

# ─── LLM provider ──────────────────────────────────────────────────────
# Brain picks the first non-empty key. At least one must be set for the
# ask/reason endpoints to function (local llama via node-llama-cpp is a
# Phase 5d addition, not in this baseline).
DINA_ANTHROPIC_API_KEY=
DINA_OPENAI_API_KEY=
DINA_GEMINI_API_KEY=

# Default model identifier. Format: `provider:model`. Override to point
# at a larger model for complex reasoning.
DINA_MODEL_DEFAULT=anthropic:claude-haiku-4-5

# ─── Runtime ───────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal | silent
DINA_LOG_LEVEL=info
