# Dina Shared Infrastructure — Deployment Configuration
# Copy to infra.env and fill in before deploying.
# This file is gitignored. Never commit infra.env.

# ── Server ──
REMOTE=dina-infra                    # SSH alias or user@host
REMOTE_DIR=/opt/dina-infra           # Deployment directory on server

# ── Domain ──
DOMAIN=dinakernel.com                # Base domain
PDS_HOST=pds.dinakernel.com          # Community PDS subdomain
MSGBOX_HOST=mailbox.dinakernel.com   # D2D MsgBox subdomain
APPVIEW_HOST=appview.dinakernel.com  # Trust Network subdomain

# ── Secrets (generated on first deploy, stored on server in .env) ──
# These are NOT stored here. They live only on the server at $REMOTE_DIR/deploy/.env
# Generated by: openssl rand -hex 16 (for passwords)
#               openssl rand -base64 32 (for JWT)
#               openssl ecparam -name secp256k1 -genkey -noout (for PDS rotation key)
