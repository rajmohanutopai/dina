# Dina Shared Infrastructure — Environment Variables
# Copy to .env and fill in before deploying.

# PostgreSQL (AppView database)
POSTGRES_PASSWORD=

# PDS (AT Protocol)
PDS_ADMIN_PASSWORD=
PDS_JWT_SECRET=
PDS_ROTATION_KEY=

# Generated by: openssl rand -base64 32
# PDS_ROTATION_KEY: openssl ecparam -name secp256k1 -genkey -noout | openssl ec -text -noout 2>/dev/null | grep priv -A 3 | tail -n +2 | tr -d ':\n '
