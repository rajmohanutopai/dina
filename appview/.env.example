# Database
DATABASE_URL=postgresql://dina:changeme@localhost:5432/dina_reputation
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Jetstream — local container on Docker network
JETSTREAM_URL=ws://jetstream:6008

# Web server
NEXT_PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_RPM=60

# Docker Compose
POSTGRES_PASSWORD=changeme

# Relay URL (default: Bluesky global relay)
# RELAY_URL=wss://bgs.bsky.network
# For sovereign operation:
# RELAY_URL=wss://relay.dina.foundation
