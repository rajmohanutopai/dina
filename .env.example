# Multi-provider config — set one or both (provider/model format)
DINA_LIGHT=ollama/gemma3                  # fast, cheap, private
DINA_HEAVY=gemini/gemini-2.5-flash        # powerful, multimodal

# Embedding model (inferred from light provider if omitted)
DINA_EMBED=ollama/nomic-embed-text

# Both can be the same provider at different tiers:
# DINA_LIGHT=gemini/gemini-2.5-flash-lite
# DINA_HEAVY=gemini/gemini-3-pro
# DINA_EMBED=gemini/gemini-embedding-001

# Or use a single model for everything:
# DINA_LIGHT=ollama/gemma3

# Provider-specific config
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Ceramic Vault (v0.4) ---
# Set to enable decentralized verdict storage. Leave empty to disable.
# DINA_CERAMIC_URL=http://localhost:7007
