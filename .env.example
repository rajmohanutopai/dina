# Dina Home Node — Environment Configuration
#
# Copy to .env and fill in your keys.
# At minimum, set one LLM provider API key.

# --- LLM Providers (set at least one) ---

# Gemini (free tier: https://aistudio.google.com/apikey)
# GEMINI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=

# OpenRouter — access OpenAI, Claude, Gemini, and 200+ models via one key
# (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash

# Ollama — local models, fully private (https://ollama.com)
# OLLAMA_BASE_URL=http://localhost:11434

# --- v0.2-v0.4 legacy config (chat REPL) ---

# Multi-provider config — set one or both (provider/model format)
# DINA_LIGHT=ollama/gemma3
# DINA_HEAVY=gemini/gemini-2.5-flash
# DINA_EMBED=ollama/nomic-embed-text

# --- Ceramic Vault (v0.4, optional) ---
# DINA_CERAMIC_URL=http://localhost:7007
