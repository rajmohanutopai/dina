{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "../..",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src",
    "__tests__",
    "audit.ts",
    "d2d.ts",
    "devices.ts",
    "kv.ts",
    "reminders.ts",
    "runtime.ts",
    "storage.ts"
  ]
}
