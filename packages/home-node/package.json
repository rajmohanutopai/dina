{
  "name": "@dina/home-node",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript Home Node runtime contract for mobile and server adapters.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
