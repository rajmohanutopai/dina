      "default": "./service-runtime.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dina/brain": "*",
    "@dina/core": "*",
    "@dina/protocol": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0"
  }
}
