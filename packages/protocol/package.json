{
  "name": "@dina/protocol",
  "version": "0.0.1",
  "private": true,
  "description": "Dina wire-format protocol — types, canonical-sign helpers, envelope builders, frame constants. Zero runtime deps; independently consumable so any language/runtime implementing the Dina protocol can depend on this without the rest of @dina/core.",
  "keywords": [
    "dina",
    "protocol",
    "did",
    "d2d",
    "atproto"
  ],
  "license": "MIT",
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "docs/"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "require": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "test": "jest",
    "conformance": "tsx conformance/cli.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@noble/hashes": "^2.0.0",
    "@scure/base": "^2.0.0",
    "@types/jest": "^29.5.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "jest": "^29.7.0",
    "libsodium-wrappers": "^0.7.13",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0"
  }
}
