#!/usr/bin/env bash
# dina-admin — thin wrapper that runs dina-admin inside the Core container.
#
# Usage:
#   ./dina-admin status
#   ./dina-admin --json persona list
#   ./dina-admin device pair
#   ./dina-admin security auto-start    # store passphrase locally
#   ./dina-admin security manual-start  # require passphrase on each start
#
# Most commands are forwarded to the container's dina-admin CLI.
# The "security" subcommand runs on the host (manages secrets/seed_password).

set -euo pipefail

COMPOSE_DIR="$(cd "$(dirname "$0")" && pwd)"
SECRETS_DIR="${COMPOSE_DIR}/secrets"
SEED_PASSWORD_FILE="${SECRETS_DIR}/seed_password"

# Colors (if terminal)
if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
    CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
else
    GREEN=''; YELLOW=''; RED=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

if docker compose version >/dev/null 2>&1; then
    COMPOSE="docker compose"
elif command -v docker-compose >/dev/null 2>&1; then
    COMPOSE="docker-compose"
else
    echo "Error: docker compose not found" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Host-side "security" subcommand
# ---------------------------------------------------------------------------

_security_usage() {
    echo -e "  ${BOLD}Usage:${RESET} dina-admin security <command>"
    echo ""
    echo "  Commands:"
    echo -e "    ${CYAN}auto-start${RESET}      Store passphrase locally (Dina starts without prompting)"
    echo -e "    ${CYAN}manual-start${RESET}    Require passphrase on each start (most secure)"
    echo -e "    ${CYAN}status${RESET}          Show current startup mode"
}

_security_status() {
    if [ ! -f "${SEED_PASSWORD_FILE}" ]; then
        echo -e "  ${YELLOW}unknown${RESET} — seed_password file not found (run install.sh first)"
        return
    fi
    if [ -s "${SEED_PASSWORD_FILE}" ]; then
        echo -e "  Startup mode: ${GREEN}auto-start${RESET} ${DIM}(passphrase stored locally)${RESET}"
    else
        echo -e "  Startup mode: ${CYAN}manual-start${RESET} ${DIM}(passphrase required on each start)${RESET}"
    fi
}

_security_auto_start() {
    if [ ! -f "${SEED_PASSWORD_FILE}" ]; then
        echo -e "  ${RED}Error:${RESET} seed_password file not found. Run install.sh first." >&2
        exit 1
    fi
    if [ -s "${SEED_PASSWORD_FILE}" ]; then
        echo -e "  Already in ${GREEN}auto-start${RESET} mode."
        return
    fi
    echo -e "  Switching to ${GREEN}auto-start${RESET} mode."
    echo -e "  ${DIM}Your passphrase will be stored locally so Dina can start without prompting.${RESET}"
    echo ""
    printf "  ${BOLD}Passphrase:${RESET} "
    read -rs passphrase
    echo ""
    if [ -z "${passphrase}" ]; then
        echo -e "  ${RED}Error:${RESET} Passphrase cannot be empty." >&2
        exit 1
    fi
    printf '%s' "${passphrase}" > "${SEED_PASSWORD_FILE}"
    chmod 600 "${SEED_PASSWORD_FILE}"
    echo -e "  ${GREEN}✓${RESET} Passphrase stored. Dina will start automatically."
    echo -e "  ${DIM}Switch back: ${CYAN}dina-admin security manual-start${RESET}"
}

_security_manual_start() {
    if [ ! -f "${SEED_PASSWORD_FILE}" ]; then
        echo -e "  ${RED}Error:${RESET} seed_password file not found. Run install.sh first." >&2
        exit 1
    fi
    if [ ! -s "${SEED_PASSWORD_FILE}" ]; then
        echo -e "  Already in ${CYAN}manual-start${RESET} mode."
        return
    fi
    : > "${SEED_PASSWORD_FILE}"
    chmod 600 "${SEED_PASSWORD_FILE}"
    echo -e "  ${GREEN}✓${RESET} Passphrase removed. You will be prompted on each start."
    echo -e "  ${DIM}Switch back: ${CYAN}dina-admin security auto-start${RESET}"
}

# Handle "security" subcommand on the host side
if [ "${1:-}" = "security" ]; then
    case "${2:-}" in
        auto-start)    _security_auto_start ;;
        manual-start)  _security_manual_start ;;
        status)        _security_status ;;
        *)             _security_usage ;;
    esac
    exit 0
fi

# ---------------------------------------------------------------------------
# Host-side "model" subcommand — queries Brain for LLM provider info
# ---------------------------------------------------------------------------

_model_usage() {
    echo -e "  ${BOLD}Usage:${RESET} dina-admin model <command>"
    echo ""
    echo "  Commands:"
    echo -e "    ${CYAN}list${RESET}                          Show active and available models"
    echo -e "    ${CYAN}status${RESET}                        Same as list"
    echo -e "    ${CYAN}set${RESET}                           Interactive model selection"
    echo -e "    ${CYAN}set${RESET} <role> <model>            Set directly (role: lite, primary, heavy)"
    echo ""
    echo -e "  ${DIM}Examples:${RESET}"
    echo -e "    ${CYAN}dina-admin model set${RESET}                                      ${DIM}(interactive)${RESET}"
    echo -e "    ${CYAN}dina-admin model set lite gemini/gemini-2.5-flash${RESET}         ${DIM}(direct)${RESET}"
    echo -e "    ${CYAN}dina-admin model set heavy claude/claude-sonnet-4-6${RESET}       ${DIM}(direct)${RESET}"
}

_brain_healthz() {
    $COMPOSE -f "$COMPOSE_DIR/docker-compose.yml" exec -T brain \
        python -c "import httpx,json; print(json.dumps(httpx.get('http://localhost:8200/healthz',timeout=5).json()))" \
        2>/dev/null
}

_model_list() {
    local health
    health=$(_brain_healthz) || {
        echo -e "  ${RED}Cannot reach Brain.${RESET} Is Dina running?" >&2
        exit 1
    }

    local router
    router=$(echo "${health}" | jq -r '.llm_router // empty' 2>/dev/null || true)

    if [ "${router}" = "available" ]; then
        echo -e "  ${BOLD}Active models:${RESET}"
        echo ""
        local lite primary heavy
        lite=$(echo "${health}" | jq -r '.llm_models.lite // "?"' 2>/dev/null || echo "?")
        primary=$(echo "${health}" | jq -r '.llm_models.primary // "?"' 2>/dev/null || echo "?")
        heavy=$(echo "${health}" | jq -r '.llm_models.heavy // "?"' 2>/dev/null || echo "?")
        printf "    ${GREEN}●${RESET} %-10s %s\n" "Lite:" "$lite"
        printf "    ${GREEN}●${RESET} %-10s %s\n" "Primary:" "$primary"
        printf "    ${GREEN}●${RESET} %-10s %s\n" "Heavy:" "$heavy"
    else
        echo -e "  ${YELLOW}No LLM provider configured.${RESET}"
    fi

    # Show available models from models.json
    local json_file="$COMPOSE_DIR/models.json"
    if [ -f "$json_file" ]; then
        echo ""
        echo -e "  ${BOLD}Available models:${RESET}"
        echo ""
        jq -r '.providers | to_entries[] | .key as $p | .value.models // {} | keys[] | "    \($p)/\(.)"' \
            "$json_file" 2>/dev/null
    fi

    echo ""
    echo -e "  ${BOLD}To change:${RESET}  ${CYAN}dina-admin model set${RESET}  ${DIM}(interactive)${RESET}"
}

_model_status() {
    _model_list
}

_model_set() {
    local json_file="$COMPOSE_DIR/models.json"

    if [ ! -f "$json_file" ]; then
        echo -e "  ${RED}models.json not found.${RESET} Run ./install.sh first." >&2
        exit 1
    fi

    # Non-interactive: dina-admin model set <role> <model>
    if [ -n "${1:-}" ] && [ -n "${2:-}" ]; then
        local role="$1" model="$2"
        case "$role" in
            lite|primary|heavy) ;;
            *)
                echo -e "  ${RED}Unknown role:${RESET} $role" >&2
                echo -e "  ${DIM}Valid roles: lite, primary, heavy${RESET}"
                exit 1
                ;;
        esac
        # Validate model exists in models.json
        local found
        found=$(jq -r --arg m "$model" \
            '.providers | to_entries[] | .key as $p | .value.models // {} | keys[] | "\($p)/\(.)"' \
            "$json_file" 2>/dev/null | grep -F "$model" | head -1 || true)
        if [ -z "$found" ]; then
            echo -e "  ${YELLOW}Warning:${RESET} '$model' not found in models.json (setting anyway)"
            # Try to construct full ref — if model contains /, use as-is
            if echo "$model" | grep -q "/"; then
                found="$model"
            else
                found="$model"
            fi
        fi
        # Update models.json
        local tmp="${json_file}.tmp"
        jq --arg role "$role" --arg val "$found" \
            '.defaults[$role] = $val' "$json_file" > "$tmp" && mv "$tmp" "$json_file"
        echo -e "  ${GREEN}✓${RESET} Set ${BOLD}${role}${RESET} = ${found}"
        echo ""
        echo -e "  ${DIM}Restart to apply: ${CYAN}./run.sh --stop${RESET}${DIM} then ${CYAN}./run.sh --start${RESET}"
        return
    fi

    # Interactive mode
    if [ ! -t 0 ]; then
        echo -e "  ${RED}Usage:${RESET} dina-admin model set <role> <model>" >&2
        echo -e "  ${DIM}Roles: lite, primary, heavy${RESET}"
        echo -e "  ${DIM}Example: dina-admin model set lite gemini/gemini-2.5-flash${RESET}"
        exit 1
    fi

    # Collect available models once
    local models=()
    while IFS= read -r m; do
        models+=("$m")
    done < <(jq -r '.providers | to_entries[] | .key as $p | .value.models // {} | keys[] | "\($p)/\(.)"' \
        "$json_file" 2>/dev/null | grep -v "llama-local")

    echo ""
    echo -e "  ${BOLD}Available models:${RESET}"
    echo ""
    local i=1
    for m in "${models[@]}"; do
        printf "    ${CYAN}%2d)${RESET} %s\n" "$i" "$m"
        i=$((i + 1))
    done

    local changed=false

    # Walk through all three roles
    for role_name in lite primary heavy; do
        local cur
        cur=$(jq -r --arg r "$role_name" '.defaults[$r] // "?"' "$json_file" 2>/dev/null || echo "?")
        echo ""
        printf "  ${BOLD}%-8s${RESET} ${DIM}(current: %s)${RESET}\n" "${role_name}:" "$cur"
        printf "  Enter number, paste model name, or press Enter to keep: "
        local model_input
        read -r model_input

        # Skip if empty (keep current)
        if [ -z "$model_input" ]; then
            continue
        fi

        local selected=""
        # Check if it's a number
        if echo "$model_input" | grep -qE '^[0-9]+$'; then
            local idx=$((model_input - 1))
            if [ $idx -ge 0 ] && [ $idx -lt ${#models[@]} ]; then
                selected="${models[$idx]}"
            else
                echo -e "  ${YELLOW}Invalid number — skipping.${RESET}"
                continue
            fi
        else
            # Treat as model name — find matching full ref
            selected=$(printf '%s\n' "${models[@]}" | grep -F "$model_input" | head -1 || true)
            if [ -z "$selected" ]; then
                selected="$model_input"
                echo -e "  ${YELLOW}Warning:${RESET} '$model_input' not in models.json (setting anyway)"
            fi
        fi

        # Update models.json
        local tmp="${json_file}.tmp"
        jq --arg role "$role_name" --arg val "$selected" \
            '.defaults[$role] = $val' "$json_file" > "$tmp" && mv "$tmp" "$json_file"
        echo -e "  ${GREEN}✓${RESET} ${role_name} = ${selected}"
        changed=true
    done

    if [ "$changed" = true ]; then
        echo ""
        echo -e "  ${DIM}Restart to apply: ${CYAN}./run.sh --stop${RESET}${DIM} then ${CYAN}./run.sh --start${RESET}"
    else
        echo ""
        echo -e "  ${DIM}No changes made.${RESET}"
    fi
}

if [ "${1:-}" = "model" ]; then
    case "${2:-}" in
        list)    _model_list ;;
        status)  _model_status ;;
        set)     _model_set "${3:-}" "${4:-}" ;;
        *)       _model_usage ;;
    esac
    exit 0
fi

# ---------------------------------------------------------------------------
# Host-side "logs" subcommand — tail container logs
# ---------------------------------------------------------------------------

if [ "${1:-}" = "logs" ]; then
    shift
    service=""
    tail_lines="50"
    follow=false

    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--follow)  follow=true; shift ;;
            -n|--lines)   tail_lines="$2"; shift 2 ;;
            core|brain|pds) service="$1"; shift ;;
            *)            shift ;;
        esac
    done

    if [ -n "$service" ]; then
        if [ "$follow" = true ]; then
            exec $COMPOSE -f "$COMPOSE_DIR/docker-compose.yml" logs -f --tail="$tail_lines" "$service"
        else
            $COMPOSE -f "$COMPOSE_DIR/docker-compose.yml" logs --tail="$tail_lines" "$service"
        fi
    else
        if [ "$follow" = true ]; then
            exec $COMPOSE -f "$COMPOSE_DIR/docker-compose.yml" logs -f --tail="$tail_lines"
        else
            $COMPOSE -f "$COMPOSE_DIR/docker-compose.yml" logs --tail="$tail_lines"
        fi
    fi
    exit 0
fi

# All other commands: forward to the container
exec $COMPOSE -f "$COMPOSE_DIR/docker-compose.yml" exec -T core dina-admin "$@"
